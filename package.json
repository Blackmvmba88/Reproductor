{
  "name": "blackmamba-music-performance",
  "private": true,
  "version": "0.2.0",
  "main": "electron/main.cjs",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "doctor": "node scripts/doctor.mjs",
    "clean": "node scripts/clean.mjs",
    "library:usb": "node scripts/consolidate-downloads-to-usb.mjs",
    "library:finalize": "node scripts/finalize-downloads-assets.mjs",
    "library:import-usb": "node scripts/import-usb-collection.mjs",
    "library:cleanup-usb": "node scripts/remove-consolidated-usb-copies.mjs",
    "library:dedupe-acoustic": "node scripts/dedupe-acoustic-library.mjs",
    "library:vitrine": "node scripts/sync-mp3-library.mjs",
    "library:apply-reviews": "node scripts/apply-review-decisions.mjs",
    "library:ownership": "node scripts/apply-ownership-rules.mjs",
    "library:audit-sources": "node scripts/audit-source-availability.mjs",
    "library:prepare-suno": "node scripts/prepare-suno-recovery.mjs",
    "library:merge-soundcloud": "node scripts/merge-soundcloud-catalog.mjs",
    "library:download-soundcloud": "node scripts/download-soundcloud-tracks.mjs",
    "library:download-soundcloud:dry": "node scripts/download-soundcloud-tracks.mjs --dry-run",
    "library:watch-downloads": "node scripts/watch-downloads.mjs",
    "library:rebuild-catalog": "node scripts/sync-mp3-library.mjs && node scripts/merge-soundcloud-catalog.mjs",
    "desktop:dev": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dmg": "npm run build && electron-builder --mac dmg",
    "desktop:dmg:private": "zsh scripts/build-private-dmg.sh"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.110.2",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.9",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "9.33.0",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.3.0",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.7",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "9.33.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.3.0",
    "jsdom": "26.1.0",
    "typescript": "5.9.2",
    "typescript-eslint": "8.41.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "build": {
    "appId": "records.blackmamba.music",
    "productName": "BlackMamba Music",
    "asar": true,
    "files": [
      "dist/**/*",
      "!dist/player/*.mp3",
      "!dist/music/*.mp3",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.blackmambarecords.com/music"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "BlackMamba Music",
      "window": {
        "width": 600,
        "height": 420
      },
      "contents": [
        {
          "x": 170,
          "y": 210
        },
        {
          "x": 430,
          "y": 210,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}

#!/bin/zsh
set -eu
APP_DIR="/Users/blackmambarecords/Documents/Music 2"
HOST="127.0.0.1"
PORT="${BLACKMAMBA_MUSIC_PORT:-5190}"
URL="http://${HOST}:${PORT}/"
LOG_DIR="$HOME/Library/Logs/BlackMambaMusicPerformance"
LOG_FILE="$LOG_DIR/app.log"
mkdir -p "$LOG_DIR"
if ! curl -fsS "$URL" >/dev/null 2>&1; then
  cd "$APP_DIR"
  [[ -d node_modules ]] || npm ci
  nohup npm run dev -- --host "$HOST" --port "$PORT" --strictPort >"$LOG_FILE" 2>&1 &
  for _ in {1..40}; do
    curl -fsS "$URL" >/dev/null 2>&1 && break
    sleep 0.25
  done
fi
if ! curl -fsS "$URL" >/dev/null 2>&1; then
  echo "No se pudo iniciar BlackMamba Music Performance. Revisa: $LOG_FILE" >&2
  exit 1
fi
open "$URL"
echo "BlackMamba Music Performance: $URL"
